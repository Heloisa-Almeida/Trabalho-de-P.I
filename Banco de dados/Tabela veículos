-- Veiculos
CREATE TABLE veiculos(
id INT PRIMARY KEY AUTO_INCREMENT,
tipoVeiculo varchar(30),
constraint chktipoVeiculo check(tipoVeiculo in ('Caminhão', 'Fiorino', 'Van')),
placa CHAR(7),
marca VARCHAR(20),
disponivel VARCHAR(12),
capacidade float,
CONSTRAINT chkdisponi CHECK(disponivel = 'disponivel' OR disponivel = 'indisponivel')
);
DROP TABLE veiculos;

