 -- TRANSPORTE
 
create table transporte(
	id int primary key auto_increment,
    enderecoOrigem varchar(60),
    enderecoDestino varchar(60),
	dtTransporte datetime,
    statusTransporte boolean,
    temperatura int,
    tipoTransporte varchar(30),
    constraint chkTipoTransporte check(tipoTransporte in ('caminhão', 'fiorino', 'van')),
    tempoDeslocamento int,
    tipoDeRefrigeração varchar(60)
    );

