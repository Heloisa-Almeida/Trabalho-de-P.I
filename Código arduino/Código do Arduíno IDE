const int PINO_SENSOR_TEMPERATURA = A0;
float temperatura;
void setup() {
  Serial.begin(9600);
}
void loop() {
  
  int valorLido = analogRead(PINO_SENSOR_TEMPERATURA);
  temperatura = (valorLido * 0.00488);
  temperatura = temperatura * 100;
  Serial.print("TempMaximo:");
  Serial.print(25);
  Serial.print(" ");
  Serial.print("Temperatura:");
  Serial.print(temperatura);
  Serial.print(" ");
  Serial.print("TempMinimo:");
  Serial.println(20);
  delay(2000);
}
